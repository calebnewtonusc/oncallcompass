# OncallCompass Environment Variables
# Copy to .env and fill in real values before running

# ── Required for synthesis ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Used as vLLM fallback during synthesis

# ── Required for data collection ─────────────────────────────
GITHUB_TOKEN=ghp_...                  # GitHub token for postmortem repo crawling

# ── Required for training ─────────────────────────────────────
HF_TOKEN=hf_...                       # HuggingFace token for Qwen model download

# ── Optional: Weights & Biases tracking ──────────────────────
WANDB_API_KEY=                        # Leave empty to disable W&B logging
WANDB_PROJECT=oncallcompass           # W&B project name

# ── vLLM synthesis endpoints (set after running start_vllm.sh) ─
VLLM_URLS=http://localhost:8001,http://localhost:8002,http://localhost:8003,http://localhost:8004
VLLM_API_KEY=synthesis
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Legacy endpoint vars (used by synthesize_bulk.py) ─────────
VLLM_ENDPOINT_1=http://localhost:8001
VLLM_ENDPOINT_2=http://localhost:8002
